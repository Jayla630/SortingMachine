<Window x:Class="SortingMachine.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 顶部工具栏 (Sprint S5 优化) -->
        <ToolBar DockPanel.Dock="Top" Height="40">
            <TextBlock Text="控制台主菜单" VerticalAlignment="Center" Margin="8,0"/>
        </ToolBar>

        <!-- 底部状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="锂电分选系统 v1.0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 核心显示区域 (Sprint S5 优化) -->
        <ContentControl DockPanel.Dock="Top">
            <TextBlock Text="分选流程监视面板 - Sprint S5 完善"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Foreground="Gray"/>
        </ContentControl>
    </DockPanel>
</Window>
