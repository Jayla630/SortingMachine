<UserControl x:Class="SortingMachine.Presentation.Views.MotionDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SortingMachine.Presentation.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:BoolToAlarmColorConverter x:Key="BoolToAlarmColorConverter"/>
    </UserControl.Resources>
    
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10">
            <DockPanel>
                <Button Content="紧急停止" Command="{Binding EmergencyStopCommand}" 
                        Background="Red" Foreground="White" FontSize="16" FontWeight="Bold"
                        Padding="20,10" Width="150" DockPanel.Dock="Left"/>
                
                <Button Content="全轴回零" Command="{Binding HomeAllAxesCommand}" 
                        Margin="10,0" Padding="15,5" DockPanel.Dock="Left"/>

                <Button Content="清除全报警" Command="{Binding ClearAllAlarmsCommand}" 
                        Padding="15,5" DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="系统状态: " Foreground="#666"/>
                    <TextBlock Text="{Binding PageStatus}" FontWeight="Bold" Foreground="Blue"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Axis Panels -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:AxisPanelView DataContext="{Binding AxisX}" Grid.Column="0"/>
            <local:AxisPanelView DataContext="{Binding AxisY}" Grid.Column="1"/>
            <local:AxisPanelView DataContext="{Binding AxisZ}" Grid.Column="2"/>
        </Grid>
    </Grid>
</UserControl>
