<UserControl x:Class="SortingMachine.Presentation.Views.MotionDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SortingMachine.Presentation.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:BoolToAlarmColorConverter x:Key="BoolToAlarmColorConverter"/>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource PageBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10">
            <DockPanel>
                <Button Content="紧急停止" Command="{Binding EmergencyStopCommand}" 
                        Style="{StaticResource EmergencyButton}" Width="150" DockPanel.Dock="Left"/>
                
                <Button Content="全轴回零" Command="{Binding HomeAllAxesCommand}" 
                        Style="{StaticResource SecondaryButton}" Margin="10,0" DockPanel.Dock="Left"/>

                <Button Content="清除全报警" Command="{Binding ClearAllAlarmsCommand}" 
                        Style="{StaticResource SecondaryButton}" DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="系统状态: " Foreground="{StaticResource NeutralBrush}"/>
                    <TextBlock Text="{Binding PageStatus}"
                         FontWeight="Bold"
                         Foreground="{Binding PageStatus,
                             Converter={StaticResource StatusToColorConverter},
                             Mode=OneWay}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Axis Panels -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:AxisPanelView DataContext="{Binding AxisX, Mode=OneWay}" Grid.Column="0" Margin="8"/>
            <local:AxisPanelView DataContext="{Binding AxisY, Mode=OneWay}" Grid.Column="1" Margin="8"/>
            <local:AxisPanelView DataContext="{Binding AxisZ, Mode=OneWay}" Grid.Column="2" Margin="8"/>
        </Grid>
    </Grid>
</UserControl>
