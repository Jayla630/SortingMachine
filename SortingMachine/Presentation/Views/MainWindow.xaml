<Window x:Class="SortingMachine.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:SortingMachine.Presentation.Views"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 顶部工具栏 (Sprint S5 优化) -->
        <ToolBar DockPanel.Dock="Top" Height="40">
            <TextBlock Text="控制台主菜单" VerticalAlignment="Center" Margin="8,0"/>
        </ToolBar>

        <!-- 底部状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="锂电分选系统 v1.0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 核心显示区域 (Sprint S2 引入 TabControl) -->
        <TabControl>
            <TabItem Header="运动调试">
                <local:MotionDebugView />
            </TabItem>
            <TabItem Header="分选监控">
                <TextBlock Text="Sprint S4 以后完善" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Foreground="Gray"/>
            </TabItem>
            <TabItem Header="配方管理">
                <local:RecipeView />
            </TabItem>
            <TabItem Header="报警记录">
                <TextBlock Text="Sprint S6 以后完善" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Foreground="Gray"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
