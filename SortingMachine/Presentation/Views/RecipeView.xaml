<UserControl x:Class="SortingMachine.Presentation.Views.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:SortingMachine.Presentation.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:RecipeViewModel}"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="刷新列表" Command="{Binding LoadRecipesCommand}" Width="80" Margin="0,0,5,0"/>
            <Button Content="新建默认配方" Command="{Binding CreateDefaultCommand}" Width="100" Margin="0,0,10,0"/>
            
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>
            
            <TextBlock Text="状态：" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontWeight="Bold"/>
            
            <ProgressBar IsIndeterminate="True" Width="100" Height="10" Margin="20,0,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：配方列表 -->
            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="激活选中" Command="{Binding ActivateCommand}" CommandParameter="{Binding SelectedRecipe}" 
                            Width="80" Height="30" Margin="0,0,10,0" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Button Content="复制副本" Command="{Binding DuplicateCommand}" CommandParameter="{Binding SelectedRecipe}" 
                            Width="80" Height="30" Margin="0,0,10,0"/>
                    <Button Content="删除配方" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedRecipe}" 
                            Width="80" Height="30" Foreground="DarkRed"/>
                </StackPanel>

                <GroupBox Header="配方列表">
                    <ListView ItemsSource="{Binding Recipes}" SelectedItem="{Binding SelectedRecipe}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="★ " Foreground="Orange" Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding ProductModel}" FontWeight="{Binding IsActive, ConverterParameter=Bold, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text=" [" Foreground="Gray"/>
                                    <TextBlock Text="{Binding RecipeId}" Foreground="Gray"/>
                                    <TextBlock Text="]" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </GroupBox>
            </DockPanel>

            <!-- 右侧：详情展示 -->
            <GroupBox Grid.Column="1" Header="配方详情 (只读)">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="型号：" Margin="5" Foreground="Gray"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedRecipe.ProductModel}" Margin="5" FontWeight="Bold" FontSize="16"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ID：" Margin="5" Foreground="Gray"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedRecipe.RecipeId}" Margin="5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="描述：" Margin="5" Foreground="Gray"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedRecipe.Description}" Margin="5" TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="创建时间：" Margin="5" Foreground="Gray"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedRecipe.CreatedAt}" Margin="5"/>
                        </Grid>

                        <Separator Margin="0,10"/>

                        <TextBlock Text="料仓配置" FontWeight="Bold" Margin="0,5"/>
                        <ItemsControl ItemsSource="{Binding SelectedRecipe.Bins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding BinId}" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TargetGrade, StringFormat='等级: {0}'}"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="坐标: (" Foreground="Gray"/>
                                                <TextBlock Text="{Binding X}"/>
                                                <TextBlock Text=", "/>
                                                <TextBlock Text="{Binding Y}"/>
                                                <TextBlock Text=")"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding MaxCapacity, StringFormat='容量: {0}'}" Foreground="Gray"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,10"/>

                        <TextBlock Text="运动参数" FontWeight="Bold" Margin="0,5"/>
                        <UniformGrid Columns="2">
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="XY 速度: " Foreground="Gray"/>
                                <TextBlock Text="{Binding SelectedRecipe.MotionParameters.XyVelocity}"/>
                                <TextBlock Text=" mm/s"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="Z 速度: " Foreground="Gray"/>
                                <TextBlock Text="{Binding SelectedRecipe.MotionParameters.ZVelocity}"/>
                                <TextBlock Text=" mm/s"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="安全高度: " Foreground="Gray"/>
                                <TextBlock Text="{Binding SelectedRecipe.MotionParameters.SafeZHeight}"/>
                                <TextBlock Text=" mm"/>
                            </StackPanel>
                        </UniformGrid>
                        
                        <Separator Margin="0,10"/>
                        <TextBlock Text="判定规则 (OCV/IR 阈值)" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Text="分级逻辑已在 Domain.Recipe.GradingRules 中定义" FontStyle="Italic" Foreground="Gray" Margin="5,0"/>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
