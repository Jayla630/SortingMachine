<UserControl x:Class="SortingMachine.Presentation.Views.AxisPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SortingMachine.Presentation.Views"
             xmlns:motion="clr-namespace:SortingMachine.Infrastructure.Motion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">
    <GroupBox Header="{Binding AxisName}" Margin="5">
        <StackPanel Margin="5">
            <!-- Position and Velocity -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="当前位置:" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Position, StringFormat=F3}" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text=" mm" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="当前速度:" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                    <TextBlock Text="{Binding Velocity, StringFormat=F3}"/>
                    <TextBlock Text=" mm/s" VerticalAlignment="Bottom" Margin="2,0,0,0" FontSize="10"/>
                </StackPanel>
            </Grid>

            <Separator Margin="0,5"/>

            <!-- Status Indicators -->
            <UniformGrid Columns="2" Margin="0,5">
                <StackPanel Orientation="Horizontal" Margin="2">
                    <Ellipse Width="12" Height="12" Fill="{Binding IsEnabled, Converter={StaticResource BoolToColorConverter}}"/>
                    <TextBlock Text="使能" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2">
                    <Ellipse Width="12" Height="12" Fill="{Binding IsHomed, Converter={StaticResource BoolToColorConverter}}"/>
                    <TextBlock Text="回零" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2">
                    <Ellipse Width="12" Height="12" Fill="{Binding PositiveLimitHit, Converter={StaticResource BoolToAlarmColorConverter}}"/>
                    <TextBlock Text="正限位" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2">
                    <Ellipse Width="12" Height="12" Fill="{Binding NegativeLimitHit, Converter={StaticResource BoolToAlarmColorConverter}}"/>
                    <TextBlock Text="负限位" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2">
                    <Ellipse Width="12" Height="12" Fill="{Binding HasAlarm, Converter={StaticResource BoolToAlarmColorConverter}}"/>
                    <TextBlock Text="报警" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2">
                    <Ellipse Width="12" Height="12" Fill="{Binding IsMoving, Converter={StaticResource BoolToColorConverter}}"/>
                    <TextBlock Text="运动中" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>

            <Separator Margin="0,5"/>

            <!-- Jog Controls -->
            <TextBlock Text="点动控制" FontWeight="Bold" Margin="0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="+Jog" Command="{Binding DataContext.JogPositiveCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" 
                        CommandParameter="{Binding AxisId}" Margin="2"/>
                <Button Grid.Column="1" Content="-Jog" Command="{Binding DataContext.JogNegativeCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" 
                        CommandParameter="{Binding AxisId}" Margin="2"/>
                <Button Grid.Column="2" Content="停止" Command="{Binding DataContext.StopAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" 
                        CommandParameter="{Binding AxisId}" Margin="2"/>
            </Grid>
            <DockPanel Margin="0,5">
                <TextBlock Text="点动速度:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding JogVelocity, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0" Width="60" HorizontalAlignment="Right"/>
            </DockPanel>

            <Separator Margin="0,5"/>

            <!-- Absolute Move -->
            <TextBlock Text="绝对移动" FontWeight="Bold" Margin="0,5"/>
            <DockPanel Margin="0,2">
                <TextBlock Text="目标位置:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0" Width="80" HorizontalAlignment="Right"/>
            </DockPanel>
            <DockPanel Margin="0,2">
                <TextBlock Text="移动速度:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding MoveVelocity, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0" Width="80" HorizontalAlignment="Right"/>
            </DockPanel>
            <Button Content="立即移动" Command="{Binding DataContext.MoveAbsoluteCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" 
                    CommandParameter="{Binding AxisId}" Margin="0,5"/>

            <Separator Margin="0,5"/>

            <!-- Other Operations -->
            <UniformGrid Columns="3">
                <Button Content="使能" Command="{Binding DataContext.ToggleEnableCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" 
                        CommandParameter="{Binding AxisId}" Margin="2"/>
                <Button Content="回零" Command="{Binding DataContext.HomeAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" 
                        CommandParameter="{Binding AxisId}" Margin="2"/>
                <Button Content="清警" Command="{Binding DataContext.ClearAlarmCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" 
                        CommandParameter="{Binding AxisId}" Margin="2"/>
            </UniformGrid>
        </StackPanel>
    </GroupBox>
</UserControl>
