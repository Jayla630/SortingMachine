<!-- =========================================================
     File: Presentation/Views/AlarmLogView.xaml
     Project: SortingMachine
     Sprint: S5 | Agent: Gemini CLI
     ========================================================= -->
<UserControl x:Class="SortingMachine.Presentation.Views.AlarmLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:SortingMachine.Presentation.ViewModels"
             xmlns:local="clr-namespace:SortingMachine.Presentation.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:AlarmLogViewModel}"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBgBrush}" Margin="10">
        <Grid.RowDefinitions>
            <!-- 顶部 MES 状态栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 筛选栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 核心双列显示 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. 顶部 MES 状态栏 -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="15,10" Margin="5,0,5,10">
            <DockPanel LastChildFill="True">
                <!-- 右侧动作按钮 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="检测连通" 
                            Command="{Binding PingMesCommand, Mode=OneWay}" 
                            Style="{StaticResource SecondaryButton}" 
                            Width="90" Height="32" Margin="0,0,8,0"/>
                    <Button Content="批量上报MES" 
                            Command="{Binding UploadPendingCommand, Mode=OneWay}" 
                            Style="{StaticResource PrimaryButton}" 
                            Width="120" Height="32"/>
                </StackPanel>

                <!-- 左侧 MES 状态信息 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MES 地址：" FontSize="13" Foreground="{StaticResource NeutralBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MesEndpoint, Mode=OneWay}" FontSize="13" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>

                    <!-- 连接指示灯 -->
                    <Border CornerRadius="4" Padding="8,4" Background="{StaticResource PageBgBrush}" VerticalAlignment="Center" Margin="15,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0"
                                     Fill="{Binding IsMesConnected, Converter={StaticResource BoolToColorConverter}, Mode=OneWay}"/>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#374151">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="已离线"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMesConnected, Mode=OneWay}" Value="True">
                                                <Setter Property="Text" Value="已连接"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Separator Width="1" Height="20" Background="{StaticResource BorderBrush}" Margin="5,0"/>

                    <TextBlock Text="状态：" FontSize="13" Foreground="{StaticResource NeutralBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding StatusText, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>

                    <ProgressBar IsIndeterminate="True" Width="80" Height="8" Margin="15,0,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 2. 筛选栏 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15,10" Margin="5,0,5,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="条码过滤：" VerticalAlignment="Center" Foreground="{StaticResource NeutralBrush}" FontSize="13" FontWeight="Medium" Margin="0,0,5,0"/>
                <TextBox Text="{Binding FilterCellId, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="30" Padding="8,4" VerticalContentAlignment="Center" Background="#FAFAFA" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

                <TextBlock Text="日期范围：" VerticalAlignment="Center" Foreground="{StaticResource NeutralBrush}" FontSize="13" FontWeight="Medium" Margin="20,0,5,0"/>
                <DatePicker SelectedDate="{Binding FilterFrom, Mode=TwoWay}" Width="130" Height="30" VerticalContentAlignment="Center" BorderBrush="{StaticResource BorderBrush}"/>
                <TextBlock Text="至" VerticalAlignment="Center" Foreground="{StaticResource NeutralBrush}" FontSize="13" Margin="8,0"/>
                <DatePicker SelectedDate="{Binding FilterTo, Mode=TwoWay}" Width="130" Height="30" VerticalContentAlignment="Center" BorderBrush="{StaticResource BorderBrush}"/>

                <Button Content="查询" 
                        Command="{Binding RefreshCommand, Mode=OneWay}" 
                        Style="{StaticResource PrimaryButton}" 
                        Width="80" Height="30" Margin="25,0,8,0"/>
                <Button Content="清除" 
                        Command="{Binding ClearFilterCommand, Mode=OneWay}" 
                        Style="{StaticResource SecondaryButton}" 
                        Width="80" Height="30"/>
            </StackPanel>
        </Border>

        <!-- 3. 核心显示区域 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- 左列：分选失败记录 -->
                <ColumnDefinition Width="*"/>
                <!-- 右列：待上报 MES 记录 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左边：分选失败记录 Card -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="5,0,5,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <Border DockPanel.Dock="Right" Background="{StaticResource DangerLightBrush}" CornerRadius="4" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="共 " FontSize="12" Foreground="{StaticResource DangerBrush}"/>
                                <TextBlock Text="{Binding TotalFailedCount, Mode=OneWay}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                <TextBlock Text=" 条记录" FontSize="12" Foreground="{StaticResource DangerBrush}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="分选失败记录" Style="{StaticResource CardTitle}" VerticalAlignment="Center" Margin="0"/>
                    </DockPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding FailedLogs, Mode=OneWay}" BorderThickness="0" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="Padding" Value="4,8"/>
                                <Setter Property="Background" Value="{StaticResource DangerLightBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="电芯条码" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CellId, Mode=OneWay}" FontWeight="SemiBold" Foreground="#990000"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="失败原因" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="#B71C1C" ToolTip="{Binding ErrorMessage, Mode=OneWay}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="分选时间" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SortedAt, StringFormat='yyyy-MM-dd HH:mm:ss', Mode=OneWay}" Foreground="#555555" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- 右边：待上报 MES 记录 Card -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="5,0,5,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <Border DockPanel.Dock="Right" Background="#FEF3C7" CornerRadius="4" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="待上报 " FontSize="12" Foreground="#92400E"/>
                                <TextBlock Text="{Binding PendingMesCount, Mode=OneWay}" FontSize="13" FontWeight="Bold" Foreground="#92400E"/>
                                <TextBlock Text=" 条记录" FontSize="12" Foreground="#92400E"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="待上报 MES 记录" Style="{StaticResource CardTitle}" VerticalAlignment="Center" Margin="0"/>
                    </DockPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding PendingMesLogs, Mode=OneWay}" BorderThickness="0" Background="Transparent" AlternationCount="2">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="Padding" Value="4,8"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#FAFBFD"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="电芯条码" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CellId, Mode=OneWay}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="分选等级" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="6,1" Background="#E2E8F0" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Grade, Mode=OneWay}" FontWeight="Bold" FontSize="10" Foreground="#475569"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="分配料仓" Width="75">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BinId, Mode=OneWay}" Foreground="#475569" FontWeight="Medium"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="分选时间" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SortedAt, StringFormat='yyyy-MM-dd HH:mm:ss', Mode=OneWay}" Foreground="#64748B" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="操作" Width="95">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="单条上报" 
                                                    Command="{Binding DataContext.UploadSingleCommand, RelativeSource={RelativeSource AncestorType=ListView}, Mode=OneWay}" 
                                                    CommandParameter="{Binding Mode=OneWay}" 
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="8,3" Height="24" FontSize="11" Width="75">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="3"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
